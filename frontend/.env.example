# Base URL of the read-only market-data Worker API.
# Optional: the app falls back to the deployed Worker below if this is unset,
# so you only need a .env.local when pointing at a different/local Worker
# (e.g. `wrangler dev` on http://localhost:8787).
VITE_API_BASE=https://market-data-api.shop-backend-kitweb.workers.dev
